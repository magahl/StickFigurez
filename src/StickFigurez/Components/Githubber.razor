                         M254.53 126.06c0 13.994-7.88 25.336-17.6 25.336-9.72 0-17.6-11.342-17.6-25.336 0-13.992 7.88-25.33 17.6-25.33 9.72.01 17.6 11.34 17.6 25.33z"/>
                @* Pupils *@
                <ellipse cx="142.73" cy="126.38" rx="11.73" ry="16.89" fill="currentColor" stroke="none"/>
                <ellipse cx="237.15" cy="126.38" rx="11.73" ry="16.89" fill="currentColor" stroke="none"/>
            </g>
        </g>
        @* Trail dots — bubble tail leading down toward stickman *@
        <circle cx="12" cy="11.7" r="0.5" fill="none" stroke="currentColor" stroke-width="0.3"/>
        <circle cx="10.7" cy="12.6" r="0.35" fill="none" stroke="currentColor" stroke-width="0.3"/>
    </g>

    @* Stickman *@
    @* Head *@
    <circle class="dreamer-head" cx="8" cy="12" r="2.5" fill="currentColor" stroke="none"/>
    @* Body *@
    <line x1="8" y1="14.5" x2="8" y2="20" stroke-width="2"/>
    @* Arms relaxed *@
    <line x1="8" y1="16" x2="5.5" y2="19" stroke-width="2"/>
    <line x1="8" y1="16" x2="10.5" y2="19" stroke-width="2"/>
    @* Legs *@
    <line x1="8" y1="20" x2="6" y2="23.5" stroke-width="2"/>
    <line x1="8" y1="20" x2="10" y2="23.5" stroke-width="2"/>

</svg>

@code {
    [Parameter] public int Size { get; set; } = 24;
    [Parameter] public int Speed { get; set; } = 5;

    private int ClampedSpeed => Math.Clamp(Speed, 1, 10);

    private string CycleDuration =>
        $"{(4.0 - (ClampedSpeed - 1) * 0.25).ToString("F2", CultureInfo.InvariantCulture)}s";

    private int Width => Size;
}
