@using System.Globalization

<svg class="chef-svg"
     width="@Size" height="@Size"
     viewBox="0 0 24 24"
     overflow="visible"
     style="--cook-duration: @CycleDuration;"
     xmlns="http://www.w3.org/2000/svg"
     stroke="currentColor"
     stroke-width="2"
     stroke-linecap="round"
     stroke-linejoin="round">

    @* Chef hat — single puffy dome on a band (toque shape) *@
    <g class="chef-hat" fill="currentColor" stroke="none">
        <ellipse cx="8" cy="1.3" rx="2.6" ry="1.8"/>
        <rect x="6" y="2.7" width="4" height="0.8"/>
    </g>

    @* Head *@
    <circle cx="8" cy="5" r="1.8" fill="currentColor" stroke="none"/>

    @* Body *@
    <line x1="8" y1="6.8" x2="8" y2="14"/>

    @* Left arm (relaxed at side) *@
    <line x1="8" y1="9" x2="5.5" y2="13"/>

    @* Right arm — outer group shakes horizontally for sauté.
       Inner forearm group rotates at the elbow for the flip. *@
    <g class="chef-arm">
        <line x1="8" y1="9" x2="10.5" y2="10"/>
        <g class="chef-forearm">
            <line x1="10.5" y1="10" x2="12.5" y2="10.5"/>
            @* Pan handle — short and thin *@
            <line x1="12.5" y1="10.5" x2="13.3" y2="10.5" stroke-width="1"/>
            @* Pan body — flat rim, rounded underside *@
            <path fill="currentColor" stroke="none"
                  d="M 13.3 10.5 h 4 a 2 0.7 0 0 1 -4 0 z"/>
        </g>
    </g>

    @* Legs *@
    <line x1="8" y1="14" x2="6" y2="20.5"/>
    <line x1="8" y1="14" x2="10" y2="20.5"/>

    @* Pancake — sits on the rim, then launches and flips *@
    <ellipse class="chef-pancake" cx="15.3" cy="10.15" rx="1.5" ry="0.28"
             fill="currentColor" stroke="none"/>

</svg>

@code {
    [Parameter] public int Size { get; set; } = 24;
    [Parameter] public int Speed { get; set; } = 5;

    private int Clamped => Math.Clamp(Speed, 1, 10);

    // 1.6 s at speed 1, ~0.7 s at speed 10
    private string CycleDuration =>
        $"{(1.6 - (Clamped - 1) * 0.1).ToString("F2", CultureInfo.InvariantCulture)}s";
}
