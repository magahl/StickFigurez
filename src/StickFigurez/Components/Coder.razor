@using System.Globalization

<svg class="coder-svg"
     width="@Width" height="@Size"
     viewBox="0 0 30 24"
     overflow="visible"
     style="--tap-duration: @TapDuration;"
     xmlns="http://www.w3.org/2000/svg"
     stroke="currentColor"
     stroke-width="2"
     stroke-linecap="round"
     stroke-linejoin="round">

    @* Office chair — thinner stroke than the figure *@
    <g class="coder-chair" stroke-width="1.1">
        @* Backrest *@
        <line x1="5" y1="10" x2="5" y2="16"/>
        @* Seat *@
        <line x1="5" y1="16" x2="9.5" y2="16"/>
        @* Center post *@
        <line x1="7" y1="16" x2="7" y2="19"/>
        @* Wheel struts *@
        <line x1="7" y1="19" x2="4.5" y2="20.8"/>
        <line x1="7" y1="19" x2="9.5" y2="20.8"/>
        @* Wheels *@
        <circle cx="4.5" cy="21.2" r="0.4" fill="currentColor" stroke="none"/>
        <circle cx="9.5" cy="21.2" r="0.4" fill="currentColor" stroke="none"/>
    </g>

    @* Head *@
    <circle cx="11" cy="9" r="1.8" fill="currentColor" stroke="none"/>

    @* Body — bent forward from hip to shoulder *@
    <line x1="10.5" y1="11.5" x2="7" y2="16.3"/>

    @* Single leg (side view) — thigh forward, shin down, foot forward.
       Shin uses butt linecap so its end doesn't poke past the foot. *@
    <line x1="7" y1="16.3" x2="11.5" y2="16.3"/>
    <line x1="11.5" y1="16.3" x2="11.5" y2="21" stroke-linecap="butt"/>
    <line x1="11.5" y1="21" x2="13.2" y2="21" stroke-width="1.5"/>

    @* Back arm — pivots at the elbow, taps the keyboard *@
    <g class="coder-arm-back">
        <line x1="10.3" y1="11.7" x2="12" y2="13"/>
        <g class="coder-forearm-back">
            <line x1="12" y1="13" x2="14.5" y2="14.4" stroke-width="1.4"/>
        </g>
    </g>

    @* Front arm — same idea, slightly offset, opposite phase *@
    <g class="coder-arm-front">
        <line x1="10.7" y1="12" x2="12.5" y2="13.3"/>
        <g class="coder-forearm-front">
            <line x1="12.5" y1="13.3" x2="15" y2="14.4" stroke-width="1.4"/>
        </g>
    </g>

    @* Desk + laptop — thinner stroke *@
    <g class="coder-desk" stroke-width="1.1">
        @* Desk surface *@
        <line x1="13" y1="15" x2="21" y2="15"/>
        @* Desk leg *@
        <line x1="21" y1="15" x2="21" y2="21"/>
        @* Laptop keyboard base *@
        <line x1="14" y1="14.7" x2="17.5" y2="14.7"/>
        @* Laptop screen *@
        <line x1="17.5" y1="14.7" x2="19.5" y2="11.5"/>
    </g>

</svg>

@code {
    [Parameter] public int Size { get; set; } = 24;
    [Parameter] public int Speed { get; set; } = 5;

    private int Clamped => Math.Clamp(Speed, 1, 10);

    // 0.7 s at speed 1, ~0.18 s at speed 10
    private string TapDuration =>
        $"{(0.7 - (Clamped - 1) * 0.058).ToString("F3", CultureInfo.InvariantCulture)}s";

    private int Width => (int)(Size * 30.0 / 24.0);
}
