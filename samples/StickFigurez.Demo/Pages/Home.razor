@page "/"
@using ColorCode
@inject HtmlClassFormatter Formatter
@inject NavigationManager Nav

<PageTitle>StickFigurez — Demo</PageTitle>

<FigureControls @bind-Size="size" @bind-Speed="speed" @bind-Color="color"
                MinSize="16" MaxSize="192" SizeStep="4"
                DefaultSize="100" DefaultColor="@ThemeDefaultColor"
                OnChanged="SyncUrl" OnReset="ClearUrl">
    <label class="search">
        Search
        <input type="search" placeholder="run, lock, stats…" @bind:event="oninput" @bind="query" />
    </label>
</FigureControls>

<section class="grid" style="color: @color;">
    @foreach (var f in Filtered)
    {
        var args = new FigureCatalog.FigureArgs(size, speed);
        <a class="card-link" href="@DetailUrl(f.Name)">
            <article class="card">
                <div class="stage">@f.Render(args)</div>
                <header>
                    <h2>@f.Name</h2>
                    <code class="snippet">@((MarkupString)Formatter.GetHtmlString(f.Snippet(args), Languages.Html))</code>
                </header>
            </article>
        </a>
    }
</section>

@code {
    [CascadingParameter(Name = "Theme")] public string Theme { get; set; } = "light";

    [SupplyParameterFromQuery(Name = "s")] public int? S { get; set; }
    [SupplyParameterFromQuery(Name = "v")] public int? V { get; set; }
    [SupplyParameterFromQuery(Name = "c")] public string? C { get; set; }

    private int size = 100;
    private int speed = 5;
    private string color = "#1a1a1a";
    private string query = "";

    private string ThemeDefaultColor => Theme == "dark" ? "#e5e7eb" : "#1a1a1a";

    protected override void OnParametersSet()
    {
        if (S is { } s) size = s;
        if (V is { } v) speed = v;
        color = !string.IsNullOrEmpty(C)
            ? (C.StartsWith('#') ? C : "#" + C)
            : ThemeDefaultColor;
    }

    private void SyncUrl()
    {
        var url = Nav.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["s"] = size,
            ["v"] = speed,
            ["c"] = color.TrimStart('#'),
        });
        Nav.NavigateTo(url, replace: true);
    }

    private void ClearUrl()
    {
        var url = Nav.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["s"] = null,
            ["v"] = null,
            ["c"] = null,
        });
        Nav.NavigateTo(url, replace: true);
    }

    private string DetailUrl(string name) =>
        $"/{name.ToLowerInvariant()}?s={size}&v={speed}&c={color.TrimStart('#')}";

    private IEnumerable<FigureCatalog.Figure> Filtered
    {
        get
        {
            var q = query?.Trim();
            if (string.IsNullOrEmpty(q)) return FigureCatalog.All;
            return FigureCatalog.All.Where(f =>
                f.Name.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                f.Keywords.Any(k => k.Contains(q, StringComparison.OrdinalIgnoreCase)));
        }
    }
}
