@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="page">
    <header class="topbar">
        <div class="brand">
            <img class="logo" src="stickfigurez_logo.svg" alt="" aria-hidden="true" />
            <h1>StickFigurez</h1>
        </div>
        <p class="tagline">Animated SVG stick-figure components for Blazor.</p>
        <button class="theme-toggle" type="button"
                @onclick="ToggleTheme"
                aria-label="@($"Switch to {(theme == "dark" ? "light" : "dark")} mode")"
                title="@($"Switch to {(theme == "dark" ? "light" : "dark")} mode")">
            @if (theme == "dark")
            {
                @* Sun icon *@
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <circle cx="12" cy="12" r="4" />
                    <line x1="12" y1="2" x2="12" y2="5" />
                    <line x1="12" y1="19" x2="12" y2="22" />
                    <line x1="2" y1="12" x2="5" y2="12" />
                    <line x1="19" y1="12" x2="22" y2="12" />
                    <line x1="4.93" y1="4.93" x2="7.05" y2="7.05" />
                    <line x1="16.95" y1="16.95" x2="19.07" y2="19.07" />
                    <line x1="4.93" y1="19.07" x2="7.05" y2="16.95" />
                    <line x1="16.95" y1="7.05" x2="19.07" y2="4.93" />
                </svg>
            }
            else
            {
                @* Moon icon *@
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                </svg>
            }
        </button>
    </header>
    <main>
        <CascadingValue Value="@theme" Name="Theme">
            @Body
        </CascadingValue>
    </main>
    <footer class="footer">
        <a href="https://github.com/magahl/StickFigurez">GitHub</a>
        <span>·</span>
        <a href="https://www.nuget.org/packages/StickFigurez">NuGet</a>
        <span>·</span>
        <span>MIT</span>
        <span>·</span>
        <span>v@(ThisAssembly.AssemblyInformationalVersion)</span>
    </footer>
</div>

@code {
    private string theme = "light";

    protected override void OnInitialized()
    {
        if (JS is IJSInProcessRuntime sync)
        {
            theme = sync.Invoke<string>("stickTheme.get");
        }
    }

    private async Task ToggleTheme()
    {
        theme = await JS.InvokeAsync<string>("stickTheme.toggle");
    }
}
